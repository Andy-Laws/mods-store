// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  user
  developer
  admin
}

model User {
  id            String   @id @default(cuid())
  discordId     String   @unique
  username      String?
  email         String?
  image         String?
  role          Role     @default(user)
  accessRoleIds Json?    // string[] — role IDs that grant product access (e.g. Discord role IDs)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  purchases     Purchase[]
  developers    Developer[]
  adminLogs     AdminLog[]
}

model Developer {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  logoUrl     String?
  bannerUrl   String?
  description String?   @db.Text
  socialLinks Json?     // { discord?, twitter?, website?, ... }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id               String         @id @default(cuid())
  developerId      String
  developer        Developer      @relation(fields: [developerId], references: [id], onDelete: Cascade)
  slug             String
  name             String
  shortDescription String?        @db.Text
  longDescription  String?        @db.Text
  price            Decimal?       @db.Decimal(10, 2)
  version          String?        // display version e.g. "1.2.0"
  compatibility    String?        @db.Text
  featureList      Json?          // string[]
  published        Boolean        @default(false)
  accessRoleIds    Json?          // string[] — users with any of these in their accessRoleIds can download
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProductImage[]
  versions         ProductVersion[]
  files            ProductFile[]
  purchases        Purchase[]

  @@unique([developerId, slug])
  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

model ProductVersion {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  version     String
  changelog   String?       @db.Text
  releaseDate DateTime?     @default(now())
  fileId      String?       @unique
  file        ProductFile? @relation(fields: [fileId], references: [id])
  createdAt   DateTime      @default(now())
}

model ProductFile {
  id         String          @id @default(cuid())
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  blobUrl    String
  filename   String
  size       Int?
  mimeType   String?
  versionRef ProductVersion?
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())
  grantedBy String?  // "admin" | "discord_bot" etc.

  @@unique([userId, productId])
  @@index([userId])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model AdminLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  type      String   // "activity" | "system"
  action    String
  message   String   @db.Text
  meta      Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  @@index([createdAt])
  @@index([type])
  @@index([userId])
}
